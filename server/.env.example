# O32 日常运维平台 服务端环境配置示例
# 使用方法：复制本文件为 server/.env 并按实际修改；.env 已加入 .gitignore，不入库不入仓。

# 【必需】JWT 签名密钥（生产环境必须配置为足够长的随机串，例如 python -c "import secrets;print(secrets.token_hex(32))"）
O32OPS_SECRET_KEY=请替换为随机生成的密钥

# 数据目录（SQLite 库文件所在目录），默认 server/data
#O32OPS_DATA_DIR=D:\ITOps\O32-OpsPlatform\server\data

# 归档目录（上传文件与核对结果），默认 server/archive
#O32OPS_ARCHIVE_DIR=D:\ITOps\O32-OpsPlatform\server\archive

# SQLite 库文件路径，默认 ${O32OPS_DATA_DIR}\o32ops.db
#O32OPS_DB_PATH=D:\ITOps\O32-OpsPlatform\server\data\o32ops.db

# JWT 过期时间（小时），默认 8
#O32OPS_JWT_EXPIRE_HOURS=8

# 上传文件大小上限（字节），默认 52428800（50MB）
#O32OPS_MAX_UPLOAD_SIZE=52428800

# 初始管理员（仅首次建库时生效；默认 admin / Admin@123，首次登录强制改密）
#O32OPS_INITIAL_ADMIN=admin
#O32OPS_INITIAL_ADMIN_PASSWORD=Admin@123
